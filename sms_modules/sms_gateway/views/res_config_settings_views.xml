<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_sms_gateway" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sms_gateway</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SMS Gateway" string="SMS Gateway" name="sms_gateway" groups="mass_mailing.group_mass_mailing_user">
                    <block title="SMS Gateway Settings">
                        <setting string="Force SMS Gateway"
                                 help="Route all SMS through gateway phones instead of the default SMS provider.">
                            <field name="sms_gateway_force"/>
                        </setting>
                    </block>
                    <block title="FCM Push Notifications">
                        <setting string="Enable FCM Push"
                                 help="Send instant push notifications to gateway phones when new SMS are queued. Reduces latency from 10s to under 2s. Phones without FCM continue using polling.">
                            <field name="sms_gateway_fcm_enabled"/>
                            <div invisible="not sms_gateway_fcm_enabled" class="mt8">
                                <label for="sms_gateway_fcm_credentials_json"/>
                                <field name="sms_gateway_fcm_credentials_json"
                                       placeholder='{"type": "service_account", "project_id": "...", ...}'/>
                                <div class="text-muted mt4 mb8">
                                    Paste the full Firebase service account JSON. Alternative: file path below.
                                </div>
                                <label for="sms_gateway_fcm_credentials_path"/>
                                <field name="sms_gateway_fcm_credentials_path"
                                       placeholder="/path/to/firebase-service-account.json"/>
                            </div>
                        </setting>
                    </block>
                    <block title="SMS Gateway Status">
                        <setting string="Gateway Phones" help="Manage your registered SMS gateway phones">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="sms_gateway_phone_count" class="oe_inline"/>
                                    <span> registered phone(s), </span>
                                    <field name="sms_gateway_online_count" class="oe_inline"/>
                                    <span> online</span>
                                </div>
                                <div class="mt8">
                                    <button name="action_open_gateway_phones" type="object"
                                            string="Manage Gateway Phones"
                                            class="btn-link" icon="fa-arrow-right"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
