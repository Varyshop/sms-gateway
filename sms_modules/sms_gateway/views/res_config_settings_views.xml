<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_sms_gateway" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sms_gateway</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SMS Gateway" string="SMS Gateway" name="sms_gateway" groups="mass_mailing.group_mass_mailing_user">
                    <block title="SMS Gateway Settings">
                        <setting string="Force SMS Gateway"
                                 help="Route all SMS through gateway phones instead of the default SMS provider.">
                            <field name="sms_gateway_force"/>
                        </setting>
                    </block>
                    <block title="SMS Gateway Status">
                        <setting string="Gateway Phones" help="Manage your registered SMS gateway phones">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="sms_gateway_phone_count" class="oe_inline"/>
                                    <span> registered phone(s), </span>
                                    <field name="sms_gateway_online_count" class="oe_inline"/>
                                    <span> online</span>
                                </div>
                                <div class="mt8">
                                    <button name="action_open_gateway_phones" type="object"
                                            string="Manage Gateway Phones"
                                            class="btn-link" icon="fa-arrow-right"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
