<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template Tree -->
    <record id="sms_marketing_template_view_list" model="ir.ui.view">
        <field name="name">sms.marketing.template.list</field>
        <field name="model">sms.marketing.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="phone_id"/>
                <field name="body" optional="show"/>
                <field name="default_limit"/>
                <field name="max_limit"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Template Form -->
    <record id="sms_marketing_template_view_form" model="ir.ui.view">
        <field name="name">sms.marketing.template.form</field>
        <field name="model">sms.marketing.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Template name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="phone_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="default_limit"/>
                            <field name="max_limit"/>
                        </group>
                    </group>
                    <separator string="SMS Text"/>
                    <field name="body" placeholder="SMS text. Use {{object.name}} for partner name..."/>
                    <separator string="Available Segments"/>
                    <field name="segment_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Template Action -->
    <record id="sms_marketing_template_action" model="ir.actions.act_window">
        <field name="name">SMS Templates</field>
        <field name="res_model">sms.marketing.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Segment Tree -->
    <record id="sms_marketing_segment_view_list" model="ir.ui.view">
        <field name="name">sms.marketing.segment.list</field>
        <field name="model">sms.marketing.segment</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Segment Form -->
    <record id="sms_marketing_segment_view_form" model="ir.ui.view">
        <field name="name">sms.marketing.segment.form</field>
        <field name="model">sms.marketing.segment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Segment Action -->
    <record id="sms_marketing_segment_action" model="ir.actions.act_window">
        <field name="name">SMS Segments</field>
        <field name="res_model">sms.marketing.segment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu items -->
    <menuitem id="sms_marketing_menu_root"
              name="SMS Marketing"
              parent="mass_mailing_sms.mass_mailing_sms_menu_root"
              sequence="50"/>

    <menuitem id="sms_marketing_template_menu"
              name="Templates"
              parent="sms_marketing_menu_root"
              action="sms_marketing_template_action"
              sequence="10"/>

    <menuitem id="sms_marketing_segment_menu"
              name="Segments"
              parent="sms_marketing_menu_root"
              action="sms_marketing_segment_action"
              sequence="20"/>

</odoo>
