<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sms_gateway_inbound_view_list" model="ir.ui.view">
        <field name="name">sms.gateway.inbound.list</field>
        <field name="model">sms.gateway.inbound</field>
        <field name="arch" type="xml">
            <list string="Inbound SMS" create="false" default_order="received_at desc">
                <header>
                    <button name="action_reprocess" type="object"
                            string="Reprocess"
                            help="Re-match partner, blacklist STOP numbers and post to partner chatter"/>
                </header>
                <field name="received_at"/>
                <field name="from_number"/>
                <field name="partner_id"/>
                <field name="message"/>
                <field name="is_stop" optional="show"/>
                <field name="blacklisted" optional="show"/>
                <field name="phone_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="sms_gateway_inbound_view_form" model="ir.ui.view">
        <field name="name">sms.gateway.inbound.form</field>
        <field name="model">sms.gateway.inbound</field>
        <field name="arch" type="xml">
            <form string="Inbound SMS" create="false">
                <header>
                    <button name="action_reprocess" type="object"
                            string="Reprocess" class="btn-primary"
                            help="Re-match partner, blacklist STOP numbers and post to partner chatter"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="from_number"/>
                            <field name="to_number"/>
                            <field name="partner_id"/>
                            <field name="phone_id"/>
                        </group>
                        <group>
                            <field name="received_at"/>
                            <field name="is_stop"/>
                            <field name="blacklisted"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sms_gateway_inbound_view_search" model="ir.ui.view">
        <field name="name">sms.gateway.inbound.search</field>
        <field name="model">sms.gateway.inbound</field>
        <field name="arch" type="xml">
            <search string="Inbound SMS">
                <field name="from_number"/>
                <field name="message"/>
                <field name="partner_id"/>
                <filter string="STOP" name="filter_stop" domain="[('is_stop', '=', True)]"/>
                <filter string="Blacklisted" name="filter_blacklisted" domain="[('blacklisted', '=', True)]"/>
                <filter string="No Partner" name="filter_no_partner" domain="[('partner_id', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Gateway Phone" name="group_phone" context="{'group_by': 'phone_id'}"/>
                    <filter string="Received Date" name="group_date" context="{'group_by': 'received_at:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sms_gateway_inbound_action" model="ir.actions.act_window">
        <field name="name">Inbound SMS</field>
        <field name="res_model">sms.gateway.inbound</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No inbound SMS yet
            </p>
            <p>
                SMS received by your gateway phones appear here.
                Messages containing STOP are automatically blacklisted.
            </p>
        </field>
    </record>

    <menuitem id="sms_gateway_inbound_menu"
              name="Inbound SMS"
              parent="sms_gateway_menu_root"
              action="sms_gateway_inbound_action"
              sequence="15"/>

</odoo>
